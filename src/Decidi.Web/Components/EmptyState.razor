@* Reutiliza o CSS .empty-state já definido em app.css.
   Aceita ícone SVG via Icon e CTA opcional via CallToAction. *@

<div class="empty-state @CssClass" role="status">
    @if (Icon is not null)
    {
        <div class="empty-state-icon">@Icon</div>
    }
    <h3>@Title</h3>
    @if (!string.IsNullOrEmpty(Message))
    {
        <p>@Message</p>
    }
    @if (CallToAction is not null)
    {
        <div class="empty-state-cta">@CallToAction</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public RenderFragment? CallToAction { get; set; }
    [Parameter] public string? CssClass { get; set; }
}
