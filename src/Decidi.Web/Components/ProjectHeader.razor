@* Cabeçalho do detalhe de projeto: categoria + status, título, meta (cliente, data,
   prazo) e box de orçamento. Componente puro de apresentação — sem callbacks. *@

<div class="project-detail-header">
    <div class="pdh-left">
        <div class="pdh-badges">
            <span class="badge badge-primary">@Project.CategoryName</span>
            <StatusBadge Project="@Project.Status" />
        </div>
        <h1 class="pdh-title">@Project.Title</h1>
        <div class="pdh-meta">
            <span class="pdh-meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                @Project.ClientName
            </span>
            <span class="pdh-meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                @Project.CreatedAt.ToString("dd/MM/yyyy")
            </span>
            @if (Project.Deadline.HasValue)
            {
                <span class="pdh-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Prazo: @Project.Deadline.Value.ToString("dd/MM/yyyy")
                </span>
            }
        </div>
    </div>
    <div class="pdh-right">
        <div class="pdh-budget">
            @if (Project.BudgetMin.HasValue || Project.BudgetMax.HasValue)
            {
                <span class="pdh-budget-label">Faixa de referência</span>
                <span class="pdh-budget-value">R$ @(Project.BudgetMin?.ToString("N0") ?? "?") - R$ @(Project.BudgetMax?.ToString("N0") ?? "?")</span>
                <span class="pdh-budget-type">@(Project.BudgetType == ProjectBudgetType.Hourly ? "Por Hora" : "Preço Fixo")</span>
            }
            else
            {
                <span class="pdh-budget-label">Cliente recebe propostas</span>
                <span class="pdh-budget-value" style="font-size:1rem">O valor é definido pelos profissionais</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ProjectDto Project { get; set; } = default!;
}
