<label class="pref-row">
    <div class="pref-text">
        <div class="pref-label">@Label</div>
        @if (!string.IsNullOrEmpty(Hint))
        {
            <div class="pref-hint">@Hint</div>
        }
    </div>
    <input type="checkbox" class="pref-toggle" checked="@Checked"
        @onchange="OnChanged" />
</label>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Hint { get; set; }
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }

    private async Task OnChanged(ChangeEventArgs e)
    {
        var newValue = (bool)(e.Value ?? false);
        Checked = newValue;
        await CheckedChanged.InvokeAsync(newValue);
    }
}
