@inject NavigationManager Navigation

<div class="access-denied">
    <div class="access-denied-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#F04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
        </svg>
    </div>
    <h2>Acesso Negado</h2>
    <p>Você não tem permissão para acessar esta página.</p>
    <div class="access-denied-actions">
        <a href="/login" class="btn btn-primary">Fazer Login</a>
        <button class="btn btn-outline" @onclick='() => Navigation.NavigateTo("/")'>Voltar ao Início</button>
    </div>
</div>
