@page "/proposals/my"
@attribute [Authorize(Roles = "Freelancer")]
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>Minhas Propostas - decidi</PageTitle>

<div class="container" style="max-width:960px;margin:0 auto;padding:2rem 1.5rem">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;flex-wrap:wrap;gap:0.75rem">
        <h1 style="font-size:1.75rem;margin:0">Minhas Propostas</h1>
        <a href="/projects" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Explorar Projetos
        </a>
    </div>
    <p class="text-muted" style="margin-bottom:1.25rem">Acompanhe o status das suas propostas enviadas.</p>

    @if (loading)
    {
        <SkeletonCard Count="4" Lines="3" />
    }
    else if (allProposals.Count == 0)
    {
        <EmptyState Title="Nenhuma proposta enviada"
                    Message="Explore os projetos disponíveis e envie propostas para começar a trabalhar.">
            <Icon>
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
            </Icon>
            <CallToAction>
                <a href="/projects" class="btn btn-primary">Explorar projetos</a>
            </CallToAction>
        </EmptyState>
    }
    else
    {
        <FilterChips TValue="string"
                     Options="@statusOptions"
                     Value="@statusFilter"
                     ValueChanged="OnStatusChanged"
                     AriaLabel="Filtrar por status" />

        <div class="list-toolbar">
            <input class="form-control form-control-sm list-search" type="search"
                   placeholder="Buscar pelo título do projeto..."
                   value="@searchTerm"
                   @oninput="OnSearchInput"
                   autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" />
            <select class="form-control form-control-sm list-sort" @bind="sortBy" @bind:after="SyncQueryString">
                <option value="recent">Mais recentes</option>
                <option value="value_desc">Maior valor</option>
                <option value="value_asc">Menor valor</option>
                <option value="deadline">Menor prazo</option>
            </select>
        </div>

        @if (!filteredProposals.Any())
        {
            <EmptyState Title="Nenhuma proposta com esse filtro"
                        Message="Tente outro status ou limpe a busca.">
                <CallToAction>
                    <button type="button" class="btn btn-outline" @onclick="ClearFilters">Limpar filtros</button>
                </CallToAction>
            </EmptyState>
        }
        else
        {
            @foreach (var proposal in filteredProposals)
            {
                <div class="list-card" @onclick="() => GoToProject(proposal.ProjectId)">
                    <div class="list-card-main">
                        <div class="list-card-header">
                            <h3 class="list-card-title">@proposal.ProjectTitle</h3>
                            <StatusBadge Proposal="@proposal.Status" />
                        </div>
                        @if (!string.IsNullOrEmpty(proposal.CoverLetter))
                        {
                            <p class="list-card-desc">@(proposal.CoverLetter.Length > 150 ? proposal.CoverLetter[..150] + "..." : proposal.CoverLetter)</p>
                        }
                        <div class="list-card-meta">
                            <span class="list-card-budget">R$ @proposal.Amount.ToString("N0")</span>
                            <span class="list-card-meta-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                @proposal.DeliveryDays dias de entrega
                            </span>
                            <span class="list-card-meta-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                @proposal.CreatedAt.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                    </div>
                    @if (proposal.Status == ProposalStatus.Pending)
                    {
                        <div style="display:flex;align-items:center">
                            <button type="button" class="btn btn-danger btn-sm"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => Withdraw(proposal.Id)"
                                    disabled="@(withdrawingId == proposal.Id)">
                                @(withdrawingId == proposal.Id ? "Retirando..." : "Retirar")
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="list-card-arrow">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }
    [SupplyParameterFromQuery(Name = "q")] public string? SearchQuery { get; set; }
    [SupplyParameterFromQuery(Name = "sort")] public string? SortQuery { get; set; }

    private List<ProposalDto> allProposals = [];
    private List<ProposalDto> filteredProposals = [];
    private bool loading = true;
    private Guid? withdrawingId;

    private string statusFilter = "all";
    private string searchTerm = string.Empty;
    private string sortBy = "recent";

    private List<FilterChips<string>.FilterOption> statusOptions = [];

    protected override async Task OnInitializedAsync()
    {
        statusFilter = StatusQuery ?? "all";
        searchTerm = SearchQuery ?? string.Empty;
        sortBy = SortQuery ?? "recent";

        var result = await Api.GetMyProposalsAsync();
        allProposals = result?.ToList() ?? [];
        BuildStatusOptions();
        ApplyFilters();
        loading = false;
    }

    private void BuildStatusOptions()
    {
        int CountWhere(ProposalStatus s) => allProposals.Count(p => p.Status == s);

        statusOptions =
        [
            new("Todas", "all", allProposals.Count),
            new("Pendentes", "pending", CountWhere(ProposalStatus.Pending)),
            new("Aceitas", "accepted", CountWhere(ProposalStatus.Accepted)),
            new("Rejeitadas", "rejected", CountWhere(ProposalStatus.Rejected)),
            new("Retiradas", "withdrawn", CountWhere(ProposalStatus.Withdrawn)),
            new("Encerradas", "closed", CountWhere(ProposalStatus.ClosedByContract)),
        ];
    }

    private void ApplyFilters()
    {
        IEnumerable<ProposalDto> q = allProposals;

        q = statusFilter switch
        {
            "pending" => q.Where(p => p.Status == ProposalStatus.Pending),
            "accepted" => q.Where(p => p.Status == ProposalStatus.Accepted),
            "rejected" => q.Where(p => p.Status == ProposalStatus.Rejected),
            "withdrawn" => q.Where(p => p.Status == ProposalStatus.Withdrawn),
            "closed" => q.Where(p => p.Status == ProposalStatus.ClosedByContract),
            _ => q
        };

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim();
            q = q.Where(p =>
                p.ProjectTitle.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (p.CoverLetter?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        q = sortBy switch
        {
            "value_desc" => q.OrderByDescending(p => p.Amount).ThenByDescending(p => p.CreatedAt),
            "value_asc" => q.OrderBy(p => p.Amount).ThenByDescending(p => p.CreatedAt),
            "deadline" => q.OrderBy(p => p.DeliveryDays).ThenByDescending(p => p.CreatedAt),
            _ => q.OrderByDescending(p => p.CreatedAt)
        };

        filteredProposals = q.ToList();
    }

    private void OnStatusChanged(string value)
    {
        statusFilter = value;
        SyncQueryString();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        SyncQueryString();
    }

    private void SyncQueryString()
    {
        var qs = new Dictionary<string, object?>
        {
            ["status"] = statusFilter == "all" ? null : statusFilter,
            ["q"] = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
            ["sort"] = sortBy == "recent" ? null : sortBy,
        };
        var uri = Navigation.GetUriWithQueryParameters(qs);
        Navigation.NavigateTo(uri, replace: true);
        ApplyFilters();
    }

    private void ClearFilters()
    {
        statusFilter = "all";
        searchTerm = string.Empty;
        sortBy = "recent";
        SyncQueryString();
    }

    private void GoToProject(Guid id) => Navigation.NavigateTo($"/projects/{id}");

    private async Task Withdraw(Guid id)
    {
        if (withdrawingId is not null) return;
        withdrawingId = id;
        try
        {
            await Api.WithdrawProposalAsync(id);
            var result = await Api.GetMyProposalsAsync();
            allProposals = result?.ToList() ?? [];
            BuildStatusOptions();
            ApplyFilters();
        }
        finally
        {
            withdrawingId = null;
        }
    }
}
