@page "/proposals/my"
@attribute [Authorize(Roles = "Freelancer")]
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>Minhas Propostas - decidi</PageTitle>

<div class="container" style="max-width:960px;margin:0 auto;padding:2rem 1.5rem">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem">
        <h1 style="font-size:1.75rem;margin:0">Minhas Propostas</h1>
        <a href="/projects" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Explorar Projetos
        </a>
    </div>
    <p class="text-muted" style="margin-bottom:1.5rem">Acompanhe o status das suas propostas enviadas.</p>

    @if (loading)
    {
        <SkeletonCard Count="4" Lines="3" />
    }
    else if (proposals is null || !proposals.Any())
    {
        <EmptyState Title="Nenhuma proposta enviada"
                    Message="Explore os projetos disponíveis e envie propostas para começar a trabalhar.">
            <Icon>
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
            </Icon>
            <CallToAction>
                <a href="/projects" class="btn btn-primary">Explorar projetos</a>
            </CallToAction>
        </EmptyState>
    }
    else
    {
        @foreach (var proposal in proposals)
        {
            <div class="list-card" @onclick="() => GoToProject(proposal.ProjectId)">
                <div class="list-card-main">
                    <div class="list-card-header">
                        <h3 class="list-card-title">@proposal.ProjectTitle</h3>
                        <StatusBadge Proposal="@proposal.Status" />
                    </div>
                    @if (!string.IsNullOrEmpty(proposal.CoverLetter))
                    {
                        <p class="list-card-desc">@(proposal.CoverLetter.Length > 150 ? proposal.CoverLetter[..150] + "..." : proposal.CoverLetter)</p>
                    }
                    <div class="list-card-meta">
                        <span class="list-card-budget">R$ @proposal.Amount.ToString("N0")</span>
                        <span class="list-card-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @proposal.DeliveryDays dias de entrega
                        </span>
                        <span class="list-card-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            @proposal.CreatedAt.ToString("dd/MM/yyyy")
                        </span>
                    </div>
                </div>
                @if (proposal.Status == ProposalStatus.Pending)
                {
                    <div style="display:flex;align-items:center">
                        <button class="btn btn-danger btn-sm" @onclick:stopPropagation="true" @onclick="() => Withdraw(proposal.Id)">Retirar</button>
                    </div>
                }
                else
                {
                    <div class="list-card-arrow">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private IEnumerable<ProposalDto>? proposals;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        proposals = await Api.GetMyProposalsAsync();
        loading = false;
    }

    private void GoToProject(Guid id) => Navigation.NavigateTo($"/projects/{id}");

    private async Task Withdraw(Guid id)
    {
        await Api.WithdrawProposalAsync(id);
        proposals = await Api.GetMyProposalsAsync();
    }

}
