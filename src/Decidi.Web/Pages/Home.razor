@page "/"
@implements IDisposable
@inject ApiClient Api
@inject NavigationManager Navigation
@inject AppState State

<PageTitle>decidi — Contrate freelancers no Brasil sem mensalidade · taxas a partir de R$3,99</PageTitle>
<HeadContent>
    <link rel="canonical" href="https://decidi.com.br/" />
    <meta name="description" content="Publique seu projeto grátis, receba propostas de freelancers brasileiros qualificados e contrate em minutos. R$3,99 fixo por contratação. Sem mensalidade. Pagamento por etapas. Avaliações reais." />
    <meta property="og:title" content="decidi — Contrate freelancers no Brasil sem mensalidade" />
    <meta property="og:description" content="Publique seu projeto grátis. Compare propostas. Contrate em minutos. Taxa fixa de R$3,99, sem mensalidade." />
    <meta property="og:url" content="https://decidi.com.br/" />
    <meta name="twitter:title" content="decidi — Contrate freelancers no Brasil sem mensalidade" />
    <meta name="twitter:description" content="Publique seu projeto grátis. Compare propostas. Contrate em minutos. Taxa fixa de R$3,99." />

    @* JSON-LD: HowTo descreve os 3 passos do "Como funciona" para rich snippets. *@
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "HowTo",
        "name": "Como contratar um freelancer na decidi",
        "description": "Três passos simples para sair do briefing à contratação.",
        "step": [
            { "@@type": "HowToStep", "position": 1, "name": "Publique seu projeto", "text": "Descreva o que você precisa, defina o escopo e escolha a categoria. Publicação totalmente gratuita." },
            { "@@type": "HowToStep", "position": 2, "name": "Receba propostas", "text": "Profissionais qualificados enviam propostas com valor, prazo e abordagem. Compare lado a lado." },
            { "@@type": "HowToStep", "position": 3, "name": "Decida e acompanhe", "text": "Aceite a melhor proposta, converse pelo chat e acompanhe cada entrega por milestones." }
        ]
    }
    </script>

    @* JSON-LD: FAQPage para a seção de perguntas frequentes — gera rich snippets no Google. *@
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "FAQPage",
        "mainEntity": [
            {
                "@@type": "Question",
                "name": "Quanto custa publicar um projeto?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Publicar é gratuito e ilimitado. Você só paga R$3,99 quando decidir contratar um profissional. Sem mensalidade, sem pacotes, sem destaque pago." }
            },
            {
                "@@type": "Question",
                "name": "Como o profissional recebe pelo trabalho?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Cada projeto pode ser dividido em milestones. O pagamento de cada etapa é liberado para o profissional quando o cliente aprova a entrega. Sobre o valor recebido incidem 12% de taxa da plataforma mais R$2,99 fixos por transação." }
            },
            {
                "@@type": "Question",
                "name": "E se a entrega não for o combinado?",
                "acceptedAnswer": { "@@type": "Answer", "text": "O pagamento da milestone só é liberado após sua aprovação. Em caso de impasse, o histórico fica registrado no chat (incluindo arquivos e prazos) e nossa equipe pode mediar a discussão." }
            },
            {
                "@@type": "Question",
                "name": "Como saber se um profissional é confiável?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Cada profissional tem perfil público com bio, habilidades, portfólio, projetos concluídos e avaliações reais de clientes anteriores. As avaliações ficam privadas até as duas partes se avaliarem, evitando retaliação." }
            },
            {
                "@@type": "Question",
                "name": "Posso fechar negócio fora da plataforma?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Não. As mensagens são monitoradas até a contratação e contatos pessoais (telefone, e-mail, redes sociais) são removidos automaticamente do chat. Isso protege cliente e profissional contra fraudes, garante o histórico do contrato e o pagamento por etapas." }
            },
            {
                "@@type": "Question",
                "name": "Há plano premium ou destaque pago?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Não. Não vendemos visibilidade. Todo profissional aparece igualmente nas buscas dos clientes. Quem se destaca é quem entrega bons trabalhos e acumula boas avaliações." }
            },
            {
                "@@type": "Question",
                "name": "Quanto tempo leva para receber propostas?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Em média, as primeiras propostas chegam nos primeiros 30 minutos após a publicação. Projetos com descrição detalhada atraem propostas mais qualificadas." }
            },
            {
                "@@type": "Question",
                "name": "Quais categorias de profissionais estão disponíveis?",
                "acceptedAnswer": { "@@type": "Answer", "text": "Desenvolvimento Web e Mobile, Design Gráfico, Marketing Digital, Redação e Tradução, Consultoria, Vídeo e Animação, Engenharia de Software, Suporte Técnico, Financeiro e Contabilidade — entre outras." }
            }
        ]
    }
    </script>
</HeadContent>

@if (State.IsAuthenticated)
{
    @* ===== AUTHENTICATED DASHBOARD com KPIs (Sprint 6.1 / 6.2) ===== *@
    <div class="container" style="padding:2rem 1.5rem">
        <div class="dashboard-welcome">
            <h1 style="font-size:1.75rem;margin-bottom:0.25rem">
                Olá, <span class="gradient-text">@State.UserName</span>!
            </h1>
            <p class="text-muted">@GetWelcomeMessage()</p>
        </div>

        @if (State.IsFreelancer)
        {
            <div class="kpi-grid">
                <a class="kpi-card" href="/proposals/my">
                    <span class="kpi-label">Ganhos no mês</span>
                    <span class="kpi-value">R$ @((freelancerStats?.EarningsThisMonth ?? 0).ToString("N2"))</span>
                    <span class="kpi-hint">recebidos (líquido)</span>
                </a>
                <a class="kpi-card" href="/proposals/my">
                    <span class="kpi-label">Propostas em aberto</span>
                    <span class="kpi-value">@(freelancerStats?.PendingProposals ?? 0)</span>
                    <span class="kpi-hint">aguardando resposta</span>
                </a>
                <a class="kpi-card" href="/projects/my">
                    <span class="kpi-label">Contratos ativos</span>
                    <span class="kpi-value">@(freelancerStats?.ActiveContracts ?? 0)</span>
                    <span class="kpi-hint">em execução agora</span>
                </a>
                <a class="kpi-card" href="@($"/freelancer/{State.UserId}")">
                    <span class="kpi-label">Avaliação média</span>
                    <span class="kpi-value">@((freelancerStats?.AverageRating ?? 0).ToString("0.0"))</span>
                    <span class="kpi-hint">@(freelancerStats?.TotalReviews ?? 0) avaliações</span>
                </a>
                <a class="kpi-card" href="/proposals/my">
                    <span class="kpi-label">Taxa de aceite</span>
                    <span class="kpi-value">@(((freelancerStats?.AcceptanceRate ?? 0) * 100).ToString("0"))%</span>
                    <span class="kpi-hint">propostas aceitas</span>
                </a>
            </div>
            <div class="dashboard-quicklinks">
                <a class="btn btn-primary" href="/projects">🔍 Explorar projetos</a>
                <a class="btn btn-outline" href="/proposals/my">Minhas propostas</a>
            </div>
        }
        else
        {
            <div class="kpi-grid">
                <a class="kpi-card" href="/projects/my">
                    <span class="kpi-label">Projetos ativos</span>
                    <span class="kpi-value">@(clientStats?.ActiveProjects ?? 0)</span>
                    <span class="kpi-hint">em andamento</span>
                </a>
                <a class="kpi-card highlight" href="/projects/my">
                    <span class="kpi-label">Propostas a revisar</span>
                    <span class="kpi-value">@(clientStats?.ProposalsToReview ?? 0)</span>
                    <span class="kpi-hint">aguardando sua decisão</span>
                </a>
                <a class="kpi-card" href="/chat">
                    <span class="kpi-label">Conversas</span>
                    <span class="kpi-value">@(clientStats?.Conversations ?? 0)</span>
                    <span class="kpi-hint">canais de chat ativos</span>
                </a>
                <div class="kpi-card">
                    <span class="kpi-label">Gasto na plataforma</span>
                    <span class="kpi-value">R$ @((clientStats?.TotalSpentApprox ?? 0).ToString("N0"))</span>
                    <span class="kpi-hint">somatório de contratações</span>
                </div>
            </div>
            <div class="dashboard-quicklinks">
                <a class="btn btn-primary" href="/projects/create">＋ Publicar projeto</a>
                <a class="btn btn-outline" href="/projects">Explorar profissionais</a>
            </div>
        }
    </div>
}
else
{
    @* ===================================================================
       LANDING PAGE — Conversion-focused design
       =================================================================== *@

    @* ── HERO ────────────────────────────────────────────────────────── *@
    <section class="lp-hero">
        <div class="container">
            <div class="lp-hero-content">
                <h1>
                    Encontre o freelancer certo,<br />
                    <span class="gradient-text">sem mensalidade.</span>
                </h1>
                <p class="lp-hero-sub">
                    Publique seu projeto grátis, receba propostas em minutos e
                    contrate pagando apenas <strong>R$3,99</strong>. Nada de
                    pacote, assinatura ou destaque pago.
                </p>
                <form class="lp-hero-form" @onsubmit="GoToHeroRegister" @onsubmit:preventDefault="true">
                    <label class="visually-hidden" for="hero-hint">Descreva o que você precisa</label>
                    <input id="hero-hint" type="search" autocomplete="off"
                        autocapitalize="sentences" autocorrect="on" enterkeyhint="go"
                        placeholder="O que você precisa? Ex: site da minha loja"
                        @bind="heroHint" @bind:event="oninput" maxlength="200" />
                    <button type="submit" class="btn btn-primary btn-xl">Publicar projeto grátis</button>
                </form>

                <div class="lp-hero-actions">
                    <a href="/register?role=freelancer" class="btn btn-ghost btn-xl">
                        Sou profissional, quero receber propostas
                    </a>
                </div>
                <p class="lp-hero-actions-note">
                    Cliente: publica grátis, paga <strong>R$3,99</strong> só ao contratar.
                    Profissional: <strong>12% + R$2,99</strong> só sobre o que receber.
                </p>

                <div class="lp-hero-stats">
                    <div class="lp-hero-stat">
                        <div class="num">@FormatNumber(stats?.TotalProjects ?? 0)</div>
                        <div class="lbl">Projetos publicados</div>
                    </div>
                    <div class="lp-hero-stat">
                        <div class="num">@FormatNumber(stats?.ActiveFreelancers ?? 0)</div>
                        <div class="lbl">Freelancers cadastrados</div>
                    </div>
                    <div class="lp-hero-stat">
                        <div class="num">@FormatNumber(stats?.CompletedProjects ?? 0)</div>
                        <div class="lbl">Projetos concluídos</div>
                    </div>
                    <div class="lp-hero-stat">
                        <div class="num">@categoryCount+</div>
                        <div class="lbl">Categorias</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ── TRUST BAR ───────────────────────────────────────────────────── *@
    <section class="lp-trust">
        <div class="container">
            <div class="lp-trust-inner">
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">&#128274;</div>
                    <span>Pagamento seguro por etapas</span>
                </div>
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">&#9889;</div>
                    <span>Propostas em minutos</span>
                </div>
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">&#128172;</div>
                    <span>Chat em tempo real</span>
                </div>
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">&#9878;</div>
                    <span>Mesma oportunidade a todos</span>
                </div>
            </div>
        </div>
    </section>

    @* ── COMO FUNCIONA ───────────────────────────────────────────────── *@
    <section class="lp-section" id="como-funciona">
        <div class="container">
            <div class="lp-section-head">
                <div class="lp-section-badge">Como funciona</div>
                <h2>Do briefing à contratação em três passos</h2>
                <p>Sem cadastro pago, sem etapas burocráticas, sem espera longa.</p>
            </div>
            <div class="lp-steps">
                <div class="lp-step">
                    <div class="lp-step-num">1</div>
                    <h3>Publique o projeto</h3>
                    <p>
                        Descreva o que precisa, o prazo desejado e selecione a
                        categoria. Você não precisa definir o valor — os profissionais
                        propõem. Publicação gratuita e ilimitada.
                    </p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num">2</div>
                    <h3>Receba e compare propostas</h3>
                    <p>
                        Em média, as primeiras propostas chegam em 30 minutos. Compare
                        valor, prazo, abordagem e perfil de cada profissional lado a
                        lado, com calma.
                    </p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num">3</div>
                    <h3>Contrate e acompanhe</h3>
                    <p>
                        Aceite a proposta que faz mais sentido. Combine os detalhes
                        pelo chat e acompanhe o trabalho dividido em milestones —
                        cada pagamento só é liberado após sua aprovação.
                    </p>
                </div>
            </div>
            <div class="lp-section-cta">
                <a href="/register" class="btn btn-primary btn-lg">Publicar meu projeto agora</a>
            </div>
        </div>
    </section>

    @* ── PRICING ─────────────────────────────────────────────────────── *@
    <section class="lp-section alt">
        <div class="container">
            <div class="lp-section-head">
                <div class="lp-section-badge">Transparência total</div>
                <h2>Taxas que cabem no bolso</h2>
                <p>Sem surpresas. Sem mensalidade. Você só paga quando usa a plataforma.</p>
            </div>
            <div class="lp-pricing-grid">
                @* Client pricing card *@
                <div class="lp-price-card">
                    <div class="lp-price-icon">&#128188;</div>
                    <h3>Para Clientes</h3>
                    <div class="lp-price-role">Quem publica projetos</div>
                    <div class="lp-price-val">R$3,99 <span>/ contratação</span></div>
                    <div class="lp-price-desc">Publique grátis. Pague apenas R$3,99 ao encontrar e contratar o profissional ideal.</div>
                    <ul class="lp-price-list">
                        <li><span class="lp-price-check">&#10003;</span> Publicação gratuita e ilimitada</li>
                        <li><span class="lp-price-check">&#10003;</span> Receba propostas de freelancers</li>
                        <li><span class="lp-price-check">&#10003;</span> Chat em tempo real</li>
                        <li><span class="lp-price-check">&#10003;</span> Pagamento por milestones</li>
                        <li><span class="lp-price-check">&#10003;</span> Avaliações e reviews</li>
                        <li><span class="lp-price-check">&#10003;</span> Zero mensalidade</li>
                    </ul>
                    <a href="/register" class="btn btn-primary w-full">Comece Agora</a>
                </div>

                @* Freelancer pricing card *@
                <div class="lp-price-card featured">
                    <div class="lp-price-icon">&#128187;</div>
                    <h3>Para Freelancers</h3>
                    <div class="lp-price-role">Quem envia propostas</div>
                    <div class="lp-price-val">12% <span>+ R$2,99</span></div>
                    <div class="lp-price-desc">Percentual sobre o valor recebido + taxa fixa por transação.</div>
                    <ul class="lp-price-list">
                        <li><span class="lp-price-check">&#10003;</span> Acesso a todos os projetos</li>
                        <li><span class="lp-price-check">&#10003;</span> Envie propostas ilimitadas</li>
                        <li><span class="lp-price-check">&#10003;</span> Perfil profissional completo</li>
                        <li><span class="lp-price-check">&#10003;</span> Avaliações de clientes</li>
                        <li><span class="lp-price-check">&#10003;</span> Portfólio integrado</li>
                        <li><span class="lp-price-check">&#10003;</span> Só paga se receber</li>
                    </ul>
                    <a href="/register" class="btn btn-white w-full">Cadastre-se Grátis</a>
                </div>
            </div>
        </div>
    </section>

    @* ── DIFERENCIAIS ─────────────────────────────────────────────────── *@
    <section class="lp-section" id="diferenciais">
        <div class="container">
            <div class="lp-section-head">
                <div class="lp-section-badge">Diferenciais</div>
                <h2>O que torna a decidi diferente</h2>
                <p>Plataforma feita para ser justa nos dois lados — cliente e profissional.</p>
            </div>
            <div class="lp-features">
                <div class="lp-feature">
                    <div class="lp-feature-icon" aria-hidden="true">&#128176;</div>
                    <h4>Zero mensalidade</h4>
                    <p>Você não paga assinatura, pacote ou plano. A cobrança acontece só quando há contratação efetiva.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-feature-icon" aria-hidden="true">&#9878;</div>
                    <h4>Sem destaque pago</h4>
                    <p>Não vendemos posição. Todo profissional concorre igual. Quem aparece é quem entrega — não quem investe mais em marketing interno.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-feature-icon" aria-hidden="true">&#128200;</div>
                    <h4>Taxa transparente e baixa</h4>
                    <p>R$3,99 fixos para o cliente ao contratar. 12% + R$2,99 para o profissional, apenas sobre o valor efetivamente recebido.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-feature-icon" aria-hidden="true">&#128274;</div>
                    <h4>Pagamento por milestones</h4>
                    <p>Divida o projeto em etapas com valor e prazo próprios. Cada pagamento é liberado quando o cliente aprova a entrega.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-feature-icon" aria-hidden="true">&#128172;</div>
                    <h4>Chat com proteção antifraude</h4>
                    <p>Conversa em tempo real entre cliente e profissional. Tentativas de tirar o contato da plataforma são removidas automaticamente.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-feature-icon" aria-hidden="true">&#11088;</div>
                    <h4>Avaliações sem retaliação</h4>
                    <p>As avaliações ficam privadas até as duas partes se avaliarem (ou após 14 dias). Sem medo de quem fala primeiro.</p>
                </div>
            </div>
        </div>
    </section>

    @* ── DEPOIMENTOS ────────────────────────────────────────────────── *@
    <section class="lp-section">
        <div class="container">
            <div class="lp-section-head">
                <div class="lp-section-badge">Quem usa</div>
                <h2>Histórias de quem confia na decidi</h2>
                <p>Profissionais e clientes que escolheram a plataforma para crescer</p>
            </div>
            <div class="lp-testimonials">
                <figure class="lp-testimonial">
                    <blockquote>
                        Publiquei meu projeto na sexta e segunda já tinha 6 propostas detalhadas.
                        Comparei lado a lado e contratei em 10 minutos — uma fração do tempo dos concorrentes.
                    </blockquote>
                    <figcaption>
                        <span class="t-avatar">M</span>
                        <span class="t-info">
                            <strong>Marina Silva</strong>
                            <span>Founder · @@marinasilva.tech</span>
                        </span>
                    </figcaption>
                </figure>
                <figure class="lp-testimonial">
                    <blockquote>
                        Já trabalhei em outras plataformas. A decidi cobra muito menos e libera o pagamento por etapas.
                        Sem dor de cabeça, sem destaques pagos. Só talento.
                    </blockquote>
                    <figcaption>
                        <span class="t-avatar">R</span>
                        <span class="t-info">
                            <strong>Rafael Costa</strong>
                            <span>Freelancer · Desenvolvimento Web</span>
                        </span>
                    </figcaption>
                </figure>
                <figure class="lp-testimonial">
                    <blockquote>
                        O chat antifraude impede a saída da plataforma — o que me deu segurança total.
                        Pagamento garantido e relacionamento transparente. Já contratei 4 projetos.
                    </blockquote>
                    <figcaption>
                        <span class="t-avatar">J</span>
                        <span class="t-info">
                            <strong>Juliana Pereira</strong>
                            <span>Diretora de Marketing</span>
                        </span>
                    </figcaption>
                </figure>
            </div>
            <p class="lp-testimonials-note">
                Depoimentos com nomes fictícios durante a fase de beta. Substituídos por reais após a abertura pública.
            </p>
        </div>
    </section>

    @* ── CATEGORIAS ──────────────────────────────────────────────────── *@
    @if (categories is not null && categories.Any())
    {
        <section class="lp-section alt">
            <div class="container">
                <div class="lp-section-head">
                    <div class="lp-section-badge">Explore</div>
                    <h2>Categorias de projetos</h2>
                    <p>Encontre profissionais especializados na área que você precisa</p>
                </div>
                <div class="grid grid-3">
                    @foreach (var cat in categories)
                    {
                        <a class="category-card" href="@($"/projects?categoryId={cat.Id}")">
                            <h3>@cat.Name</h3>
                            <p>@cat.Description</p>
                            <span class="arrow">&#8594;</span>
                        </a>
                    }
                </div>
            </div>
        </section>
    }

    @* ── PARA CLIENTES ───────────────────────────────────────────────── *@
    <section class="lp-section alt" id="para-clientes">
        <div class="container">
            <div class="lp-section-head">
                <div class="lp-section-badge">Para clientes</div>
                <h2>Para quem precisa contratar</h2>
                <p>Foco no resultado, sem perder tempo com burocracia ou mensalidade.</p>
            </div>
            <div class="lp-steps">
                <div class="lp-step">
                    <div class="lp-step-num" aria-hidden="true">&#128221;</div>
                    <h3>Publicação em minutos</h3>
                    <p>
                        Use os templates por categoria como ponto de partida. Quanto mais
                        clara a descrição, melhores as propostas que você recebe.
                    </p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num" aria-hidden="true">&#9878;</div>
                    <h3>Comparação lado a lado</h3>
                    <p>
                        Avalie valor, prazo e abordagem das propostas em uma tela só.
                        Veja perfil completo, avaliações anteriores e portfólio antes
                        de decidir.
                    </p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num" aria-hidden="true">&#128274;</div>
                    <h3>Pagamento condicionado</h3>
                    <p>
                        Divida em milestones. Aprove cada entrega no seu tempo. O
                        pagamento só é liberado depois do seu OK — sem adiantamentos
                        cegos.
                    </p>
                </div>
            </div>
            <div class="lp-section-cta">
                <a href="/register?role=client" class="btn btn-primary btn-lg">Quero contratar</a>
            </div>
        </div>
    </section>

    @* ── PARA FREELANCERS ─────────────────────────────────────────────── *@
    <section class="lp-section" id="para-profissionais">
        <div class="container">
            <div class="lp-section-head">
                <div class="lp-section-badge">Para profissionais</div>
                <h2>Para quem vive de freelas</h2>
                <p>O modelo é simples: você só paga quando recebe.</p>
            </div>
            <div class="lp-steps">
                <div class="lp-step">
                    <div class="lp-step-num" aria-hidden="true">&#128640;</div>
                    <h3>Comece sem custo</h3>
                    <p>
                        Crie seu perfil, adicione suas habilidades e portfólio, e já
                        comece a enviar propostas. Não cobramos para você se cadastrar
                        ou aplicar — nem agora, nem nunca.
                    </p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num" aria-hidden="true">&#127919;</div>
                    <h3>Visibilidade igual para todos</h3>
                    <p>
                        Aqui não existe selo dourado, plano premium nem destaque pago.
                        Quem ranqueia melhor é quem entrega — quem tem boas avaliações
                        e perfil completo.
                    </p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num" aria-hidden="true">&#128181;</div>
                    <h3>Receba com previsibilidade</h3>
                    <p>
                        Pagamento por etapas, taxa fixa transparente
                        (<strong>12% + R$2,99</strong>) só sobre o que você recebe.
                        Sem assinatura mensal, sem cobrança recorrente.
                    </p>
                </div>
            </div>
            <div class="lp-section-cta">
                <a href="/register?role=freelancer" class="btn btn-primary btn-lg">Quero receber propostas</a>
            </div>
        </div>
    </section>

    @* ── FAQ ─────────────────────────────────────────────────────────── *@
    <section class="lp-section alt" id="faq">
        <div class="container" style="max-width:820px">
            <div class="lp-section-head">
                <div class="lp-section-badge">Perguntas frequentes</div>
                <h2>Tem dúvida? A resposta provavelmente está aqui</h2>
                <p>Se restar alguma pergunta, escreva para contato@decidi.com.br — respondemos no mesmo dia útil.</p>
            </div>
            <div class="lp-faq">
                @foreach (var item in faqItems)
                {
                    <details class="lp-faq-item">
                        <summary>@item.Question</summary>
                        <div class="lp-faq-answer">@item.Answer</div>
                    </details>
                }
            </div>
        </div>
    </section>

    @* ── CTA FINAL ───────────────────────────────────────────────────── *@
    <section class="lp-cta">
        <div class="container">
            <h2>Pronto para <span class="gradient-text">decidir</span>?</h2>
            <p>
                Crie sua conta em menos de 30 segundos. Publicação grátis para clientes,
                cadastro grátis para profissionais. Você decide quando começa.
            </p>
            <div class="lp-cta-actions">
                <a href="/register" class="btn btn-primary btn-xl">Criar conta grátis</a>
                <a href="/login" class="btn btn-ghost btn-xl">Já tenho conta</a>
            </div>
        </div>
    </section>
}

@code {
    private IEnumerable<CategoryDto>? categories;
    private PublicStatsDto? stats;
    private ClientStatsDto? clientStats;
    private FreelancerStatsDto? freelancerStats;
    private int categoryCount;
    private int projectCount;
    private string heroHint = string.Empty;

    // Mantemos o mesmo conteúdo do JSON-LD FAQPage no markup visível —
    // se mudar um, mude o outro (a duplicação é proposital: leitor humano + rich snippet).
    private record FaqItem(string Question, string Answer);
    private static readonly FaqItem[] faqItems =
    [
        new("Quanto custa publicar um projeto?",
            "Publicar é gratuito e ilimitado. Você só paga R$3,99 quando decidir contratar um profissional. Sem mensalidade, sem pacotes, sem destaque pago."),
        new("Como o profissional recebe pelo trabalho?",
            "Cada projeto pode ser dividido em milestones. O pagamento de cada etapa é liberado para o profissional quando o cliente aprova a entrega. Sobre o valor recebido incidem 12% de taxa da plataforma mais R$2,99 fixos por transação."),
        new("E se a entrega não for o combinado?",
            "O pagamento da milestone só é liberado após sua aprovação. Em caso de impasse, o histórico fica registrado no chat (incluindo arquivos e prazos) e nossa equipe pode mediar a discussão."),
        new("Como saber se um profissional é confiável?",
            "Cada profissional tem perfil público com bio, habilidades, portfólio, projetos concluídos e avaliações reais de clientes anteriores. As avaliações ficam privadas até as duas partes se avaliarem, evitando retaliação."),
        new("Posso fechar negócio fora da plataforma?",
            "Não. As mensagens são monitoradas até a contratação e contatos pessoais (telefone, e-mail, redes sociais) são removidos automaticamente do chat. Isso protege cliente e profissional contra fraudes, garante o histórico do contrato e o pagamento por etapas."),
        new("Há plano premium ou destaque pago?",
            "Não. Não vendemos visibilidade. Todo profissional aparece igualmente nas buscas dos clientes. Quem se destaca é quem entrega bons trabalhos e acumula boas avaliações."),
        new("Quanto tempo leva para receber propostas?",
            "Em média, as primeiras propostas chegam nos primeiros 30 minutos após a publicação. Projetos com descrição detalhada atraem propostas mais qualificadas."),
        new("Quais categorias de profissionais estão disponíveis?",
            "Desenvolvimento Web e Mobile, Design Gráfico, Marketing Digital, Redação e Tradução, Consultoria, Vídeo e Animação, Engenharia de Software, Suporte Técnico, Financeiro e Contabilidade — entre outras.")
    ];

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;

        if (!State.IsAuthenticated)
            await State.InitializeAsync();

        if (State.IsAuthenticated)
        {
            if (State.IsFreelancer && !State.IsProfileComplete)
            {
                Navigation.NavigateTo("/onboarding");
                return;
            }

            // KPIs do dashboard — falha de um endpoint não derruba a tela.
            try
            {
                if (State.IsFreelancer)
                    freelancerStats = await Api.GetFreelancerStatsAsync();
                else if (State.IsClient)
                    clientStats = await Api.GetClientStatsAsync();
            }
            catch { /* opcional — handler global já mostra toast */ }
        }
        else
        {
            // Landing: 3 chamadas independentes em paralelo.
            var categoriesTask = State.GetCategoriesAsync();
            var projectsTask = SafeAsync(() => Api.SearchProjectsAsync(pageSize: 6));
            var statsTask = SafeAsync(() => Api.GetPublicStatsAsync());

            await Task.WhenAll(categoriesTask, projectsTask, statsTask);

            categories = categoriesTask.Result;
            var result = projectsTask.Result;
            stats = statsTask.Result;

            categoryCount = categories?.Count() ?? 0;
            projectCount = result?.TotalCount ?? 0;
        }
    }

    /// <summary>Encapsula uma chamada async de forma que falhas não interrompam o Task.WhenAll.</summary>
    private static async Task<T?> SafeAsync<T>(Func<Task<T?>> call)
    {
        try { return await call(); }
        catch { return default; }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private string GetWelcomeMessage() => State.IsFreelancer
        ? "Encontre projetos que combinam com suas habilidades."
        : "Publique projetos e encontre os melhores profissionais.";

    private void GoToHeroRegister()
    {
        var hint = heroHint?.Trim() ?? string.Empty;
        var qs = string.IsNullOrEmpty(hint) ? string.Empty : $"&hint={Uri.EscapeDataString(hint)}";
        Navigation.NavigateTo($"/register?role=client{qs}");
    }

    private static string FormatNumber(int n) => n switch
    {
        >= 1_000_000 => $"{n / 1_000_000d:0.#}M",
        >= 1_000 => $"{n / 1_000d:0.#}k",
        _ => n.ToString()
    };

    public void Dispose() => State.OnChange -= OnStateChanged;
}
