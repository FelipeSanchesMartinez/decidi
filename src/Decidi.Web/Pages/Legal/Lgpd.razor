@page "/lgpd"

<PageTitle>LGPD - decidi</PageTitle>
<HeadContent>
    <meta name="description" content="Seus direitos como titular de dados pessoais segundo a Lei Geral de Proteção de Dados (Lei 13.709/2018). Como exercê-los na decidi." />
    <link rel="canonical" href="https://decidi.com.br/lgpd" />
    <meta property="og:title" content="LGPD — Seus direitos como titular de dados — decidi" />
    <meta property="og:url" content="https://decidi.com.br/lgpd" />
</HeadContent>

<div class="container legal-page">
    <h1>LGPD — Seus direitos como titular de dados</h1>
    <p class="text-muted">Última atualização: 17 de junho de 2026 · Versão 2026-06-17</p>

    <p>
        A Lei Geral de Proteção de Dados (Lei 13.709/2018) garante a você uma série de direitos
        sobre seus dados pessoais. Esta página explica como exercer cada um deles dentro da
        decidi.
    </p>

    <h2>Quem é o controlador?</h2>
    <p>
        A decidi é a controladora dos dados que você nos fornece ao usar a plataforma. Para
        contato com nosso encarregado (DPO): <strong>dpo@decidi.com.br</strong>.
    </p>

    <h2>Seus direitos</h2>
    <ul>
        <li><strong>Confirmação e acesso:</strong> saber quais dados pessoais temos sobre você.</li>
        <li><strong>Correção:</strong> atualizar dados incompletos, inexatos ou desatualizados.</li>
        <li><strong>Anonimização, bloqueio ou eliminação</strong> de dados desnecessários, excessivos ou tratados em desconformidade.</li>
        <li><strong>Portabilidade:</strong> receber seus dados em formato estruturado.</li>
        <li><strong>Eliminação</strong> de dados tratados com base no seu consentimento.</li>
        <li><strong>Informação sobre compartilhamento</strong> com entidades públicas e privadas.</li>
        <li><strong>Revogação do consentimento</strong>, quando for a base legal aplicável.</li>
        <li><strong>Oposição</strong> a tratamentos realizados sem consentimento, quando houver descumprimento.</li>
    </ul>

    <h2>Como exercer</h2>
    <p>
        Envie um e-mail para <strong>dpo@decidi.com.br</strong> a partir do e-mail cadastrado
        em sua conta. Responderemos em até 15 dias.
    </p>

    <p>
        Você pode usar o formulário abaixo para montar a solicitação automaticamente —
        ele apenas abre seu app de e-mail com tudo preenchido. Nenhum dado é enviado
        à decidi até você confirmar o envio no seu cliente de e-mail.
    </p>

    <div class="card lgpd-request-form" style="padding:1.5rem;margin-top:1rem">
        <h3 style="font-size:1.05rem;margin:0 0 0.75rem">Montar solicitação LGPD</h3>

        <div class="form-group">
            <label>Qual direito você quer exercer? <span style="color:var(--error)">*</span></label>
            <select class="form-control" @bind="rightSelected">
                <option value="">Selecione...</option>
                <option value="confirmacao">Confirmação e acesso aos meus dados</option>
                <option value="correcao">Correção de dados incompletos ou inexatos</option>
                <option value="portabilidade">Portabilidade (receber meus dados em formato estruturado)</option>
                <option value="eliminacao">Eliminação de dados</option>
                <option value="anonimizacao">Anonimização ou bloqueio</option>
                <option value="compartilhamento">Informação sobre compartilhamento</option>
                <option value="revogacao">Revogação do consentimento</option>
                <option value="oposicao">Oposição ao tratamento</option>
                <option value="outro">Outro</option>
            </select>
        </div>

        <div class="form-group">
            <label>E-mail cadastrado na sua conta <span style="color:var(--error)">*</span></label>
            <input class="form-control" type="email"
                   @bind="accountEmail" @bind:event="oninput"
                   placeholder="seu@email.com"
                   inputmode="email" autocomplete="email"
                   autocapitalize="off" autocorrect="off" spellcheck="false" />
            <span class="form-hint">Usamos isso só para identificar você no e-mail gerado.</span>
        </div>

        <div class="form-group">
            <label>Detalhes adicionais (opcional)</label>
            <textarea class="form-control" rows="4" maxlength="2000"
                      @bind="details" @bind:event="oninput"
                      placeholder="Se quiser, descreva mais sobre sua solicitação. Ex: 'preciso dos meus dados em formato CSV', 'corrigir o telefone para X'..."
                      autocapitalize="sentences" autocorrect="on"></textarea>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center">
            <a href="@(IsValid ? MailtoLink : "#")"
               class="btn btn-primary"
               style="@(IsValid ? "" : "opacity:0.55")"
               aria-disabled="@(IsValid ? "false" : "true")"
               @onclick="HandleBuildClick"
               @onclick:preventDefault="@(!IsValid)">
                Abrir e-mail para dpo@decidi.com.br
            </a>
            <span class="text-sm text-muted">
                O e-mail abre no seu app padrão — basta revisar e enviar.
            </span>
        </div>
    </div>

    <h2>Encerramento de conta e dados remanescentes</h2>
    <p>
        Após o encerramento, podemos manter parte dos seus dados para cumprir obrigações
        legais (fiscais, fiscalização, defesa em processos) e para registro histórico de
        contratos e avaliações de outros usuários, em base agregada ou anonimizada quando
        possível.
    </p>

    <h2>Reclamações</h2>
    <p>
        Você também pode reclamar diretamente à Autoridade Nacional de Proteção de Dados
        (ANPD): <a href="https://www.gov.br/anpd" target="_blank" rel="noopener">gov.br/anpd</a>.
    </p>
</div>

@code {
    private string rightSelected = string.Empty;
    private string accountEmail = string.Empty;
    private string details = string.Empty;
    private string? errorMessage;

    private static readonly Dictionary<string, string> RightLabels = new()
    {
        ["confirmacao"] = "Confirmação e acesso aos meus dados",
        ["correcao"] = "Correção de dados incompletos ou inexatos",
        ["portabilidade"] = "Portabilidade dos meus dados",
        ["eliminacao"] = "Eliminação de dados",
        ["anonimizacao"] = "Anonimização ou bloqueio",
        ["compartilhamento"] = "Informação sobre compartilhamento",
        ["revogacao"] = "Revogação do consentimento",
        ["oposicao"] = "Oposição ao tratamento",
        ["outro"] = "Outra solicitação relacionada à LGPD",
    };

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(rightSelected)
        && !string.IsNullOrWhiteSpace(accountEmail)
        && accountEmail.Contains('@');

    private string MailtoLink
    {
        get
        {
            if (!IsValid) return "#";

            var label = RightLabels.TryGetValue(rightSelected, out var l)
                ? l
                : "Solicitação LGPD";

            var subject = $"[LGPD] {label}";
            var body =
$@"Olá, equipe de Proteção de Dados da decidi.

Sou titular dos dados pessoais associados à conta com o e-mail: {accountEmail.Trim()}

Solicito o exercício do seguinte direito previsto na LGPD (Lei 13.709/2018):
- {label}

Detalhes adicionais:
{(string.IsNullOrWhiteSpace(details) ? "(sem detalhes adicionais)" : details.Trim())}

Aguardo retorno no prazo de até 15 dias previsto em lei.

Atenciosamente.";

            return $"mailto:dpo@decidi.com.br?subject={Uri.EscapeDataString(subject)}&body={Uri.EscapeDataString(body)}";
        }
    }

    private void HandleBuildClick()
    {
        errorMessage = IsValid
            ? null
            : "Preencha o direito desejado e seu e-mail antes de gerar a solicitação.";
    }
}
