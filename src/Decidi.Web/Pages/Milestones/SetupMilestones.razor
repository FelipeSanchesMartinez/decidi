@page "/projects/{ProjectId:guid}/milestones/setup"
@attribute [Authorize(Roles = "Client")]
@inject ApiClient Api
@inject JwtAuthStateProvider AuthState
@inject NavigationManager Navigation
@inject ToastService Toast
@using System.Security.Claims

<PageTitle>Configurar etapas do projeto - decidi</PageTitle>

<div class="container" style="max-width:780px;margin:0 auto;padding:2rem 1.5rem">

    @if (loading)
    {
        <SkeletonCard Count="3" Lines="3" />
    }
    else if (project is null)
    {
        <EmptyState Title="Projeto não encontrado"
                    Message="Volte para sua lista de projetos.">
            <CallToAction>
                <a class="btn btn-primary" href="/projects/my">Meus projetos</a>
            </CallToAction>
        </EmptyState>
    }
    else if (acceptedProposal is null)
    {
        <EmptyState Title="Este projeto ainda não tem proposta aceita"
                    Message="Aceite uma proposta antes de configurar as etapas de pagamento.">
            <CallToAction>
                <a class="btn btn-primary" href="@($"/projects/{ProjectId}")">Voltar ao projeto</a>
            </CallToAction>
        </EmptyState>
    }
    else if (existingMilestonesCount > 0)
    {
        <EmptyState Title="Etapas já configuradas"
                    Message="Este projeto já tem etapas criadas. Você pode adicionar mais a qualquer momento na tela de milestones.">
            <CallToAction>
                <a class="btn btn-primary" href="@($"/projects/{ProjectId}/milestones")">Ver etapas</a>
            </CallToAction>
        </EmptyState>
    }
    else
    {
        <header style="margin-bottom:1.5rem">
            <a href="@($"/projects/{ProjectId}")" class="text-sm" style="color:var(--gray-500);text-decoration:none">← Voltar ao projeto</a>
            <h1 style="font-size:1.6rem;margin:0.5rem 0 0.25rem">Configurar etapas de pagamento</h1>
            <p class="text-muted" style="margin:0">
                Você contratou <strong>@project.AcceptedFreelancerName</strong> por
                <strong>R$ @acceptedProposal.Amount.ToString("N2")</strong> em
                <strong>@acceptedProposal.DeliveryDays dias</strong>. Divida em etapas para
                liberar pagamentos só após cada entrega aprovada — protege os dois lados.
            </p>
        </header>

        @if (currentStep == 1)
        {
            <section class="ms-wizard-step">
                <h2 class="ms-wizard-title">Como você prefere dividir?</h2>
                <p class="ms-wizard-help">
                    Escolha um modelo. Você ainda poderá ajustar título, valor e prazo de cada
                    etapa antes de confirmar.
                </p>

                <div class="ms-template-grid">
                    @foreach (var tpl in templates)
                    {
                        <button type="button" class="ms-template-card" @onclick="() => SelectTemplate(tpl.Key)">
                            <div class="ms-template-icon" aria-hidden="true">@tpl.Icon</div>
                            <div class="ms-template-name">@tpl.Name</div>
                            <div class="ms-template-desc">@tpl.Description</div>
                            <div class="ms-template-split">@tpl.SplitLabel</div>
                        </button>
                    }
                </div>

                <div class="ms-wizard-footer">
                    <a class="btn btn-ghost-dark" href="@($"/projects/{ProjectId}/milestones")">
                        Pular e configurar manualmente
                    </a>
                </div>
            </section>
        }
        else
        {
            <section class="ms-wizard-step">
                <h2 class="ms-wizard-title">Ajuste as etapas</h2>
                <p class="ms-wizard-help">
                    Edite título, valor e prazo de cada etapa. A soma dos valores precisa bater
                    com o total contratado.
                </p>

                <div class="ms-stage-list">
                    @for (var i = 0; i < draft.Count; i++)
                    {
                        var idx = i;
                        var item = draft[idx];
                        <div class="ms-stage-card">
                            <div class="ms-stage-head">
                                <span class="ms-stage-num">Etapa @(idx + 1)</span>
                                @if (draft.Count > 1)
                                {
                                    <button type="button" class="ms-stage-remove"
                                            aria-label="Remover etapa"
                                            @onclick="() => RemoveStage(idx)">×</button>
                                }
                            </div>
                            <div class="form-group">
                                <label>Título da etapa</label>
                                <input class="form-control" maxlength="200"
                                       value="@item.Title"
                                       @oninput="@(e => item.Title = e.Value?.ToString() ?? string.Empty)" />
                            </div>
                            <div class="form-row">
                                <div class="form-group" style="flex:1">
                                    <label>Valor (R$)</label>
                                    <input class="form-control" type="number" min="1" step="0.01"
                                           value="@item.Amount"
                                           @oninput="@(e => item.Amount = ParseDecimal(e.Value))" />
                                </div>
                                <div class="form-group" style="flex:1">
                                    <label>Prazo</label>
                                    <input class="form-control" type="date"
                                           value="@(item.DueDate?.ToString("yyyy-MM-dd"))"
                                           @oninput="@(e => item.DueDate = ParseDate(e.Value))" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="ms-add-stage" @onclick="AddStage">
                    + Adicionar etapa
                </button>

                <div class="ms-summary @(SumMatches ? "valid" : "invalid")">
                    <div>
                        <span class="ms-summary-label">Soma das etapas</span>
                        <strong class="ms-summary-value">R$ @CurrentSum.ToString("N2")</strong>
                    </div>
                    <div>
                        <span class="ms-summary-label">Total contratado</span>
                        <strong class="ms-summary-value">R$ @acceptedProposal.Amount.ToString("N2")</strong>
                    </div>
                    <div class="ms-summary-status">
                        @if (SumMatches) { <span>✓ Tudo certo, soma confere</span> }
                        else
                        {
                            var diff = acceptedProposal.Amount - CurrentSum;
                            <span>@(diff > 0 ? $"Faltam R$ {diff:N2}" : $"Sobram R$ {Math.Abs(diff):N2}")</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(submitError))
                {
                    <div class="alert alert-danger" style="margin-top:1rem">@submitError</div>
                }

                <div class="ms-wizard-footer">
                    <button type="button" class="btn btn-outline" @onclick="GoBackToStep1" disabled="@submitting">
                        ← Trocar modelo
                    </button>
                    <SubmitButton Type="button" IsSubmitting="@submitting"
                                  Disabled="@(!CanConfirm)"
                                  BusyText="Criando etapas..."
                                  OnClick="ConfirmAndCreate">
                        Confirmar e criar etapas
                    </SubmitButton>
                </div>
            </section>
        }
    }
</div>

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private ProjectDto? project;
    private ProposalDto? acceptedProposal;
    private int existingMilestonesCount;
    private bool loading = true;

    private int currentStep = 1;
    private List<StageDraft> draft = [];
    private bool submitting;
    private string? submitError;

    // Templates pré-definidos. Percentuais somam 100. Prazos como fração de DeliveryDays.
    private record TemplateOption(string Key, string Name, string Icon, string Description, string SplitLabel, decimal[] Percents, double[] DueAtFractions, string[] DefaultTitles);

    private static readonly TemplateOption[] templates =
    [
        new("single", "Entrega única", "🎯",
            "Pagamento integral ao final, quando o cliente aprovar a entrega completa. Ideal para projetos curtos.",
            "1 etapa · 100% no final",
            [1.00m],
            [1.00],
            ["Entrega final"]),
        new("half-half", "Duas etapas", "⚖️",
            "Metade do valor na primeira aprovação intermediária, metade na entrega final.",
            "2 etapas · 50% / 50%",
            [0.50m, 0.50m],
            [0.50, 1.00],
            ["Aprovação intermediária", "Entrega final"]),
        new("three-stage", "Três etapas", "📈",
            "Modelo comum para projetos médios e longos. Liberação progressiva acompanhando o avanço.",
            "3 etapas · 30% / 40% / 30%",
            [0.30m, 0.40m, 0.30m],
            [0.25, 0.65, 1.00],
            ["Pontapé inicial", "Aprovação intermediária", "Entrega final"]),
        new("custom", "Personalizado", "✏️",
            "Comece com uma etapa em branco e adicione quantas precisar. Sem percentuais sugeridos.",
            "Você define",
            [1.00m],
            [1.00],
            ["Etapa 1"])
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            project = await Api.GetProjectAsync(ProjectId);
            if (project is null) return;

            // Defesa em profundidade: o [Authorize(Roles=Client)] cobre, mas confirmamos a posse.
            if (project.ClientId != currentUserId)
            {
                project = null;
                return;
            }

            // Carrega propostas e milestones existentes em paralelo.
            var proposalsTask = SafeAsync(() => Api.GetProjectProposalsAsync(ProjectId));
            var milestonesTask = SafeAsync(() => Api.GetProjectMilestonesAsync(ProjectId));
            await Task.WhenAll(proposalsTask, milestonesTask);

            acceptedProposal = proposalsTask.Result?
                .FirstOrDefault(p => p.Status == ProposalStatus.Accepted);

            existingMilestonesCount = milestonesTask.Result?.Count() ?? 0;
        }
        finally
        {
            loading = false;
        }
    }

    private void SelectTemplate(string key)
    {
        if (acceptedProposal is null) return;
        var tpl = templates.First(t => t.Key == key);

        var total = acceptedProposal.Amount;
        var deliveryDays = Math.Max(1, acceptedProposal.DeliveryDays);
        var baseDate = DateTime.Today;

        draft = tpl.Percents.Select((pct, i) =>
        {
            var due = baseDate.AddDays(Math.Max(1, (int)Math.Round(tpl.DueAtFractions[i] * deliveryDays)));
            return new StageDraft
            {
                Title = i < tpl.DefaultTitles.Length ? tpl.DefaultTitles[i] : $"Etapa {i + 1}",
                Amount = Math.Round(total * pct, 2, MidpointRounding.AwayFromZero),
                DueDate = due,
            };
        }).ToList();

        // Ajuste por arredondamento: a última etapa absorve a diferença para somar exato.
        var sum = draft.Sum(s => s.Amount);
        if (sum != total && draft.Count > 0)
            draft[^1].Amount += (total - sum);

        currentStep = 2;
    }

    private void AddStage()
    {
        if (acceptedProposal is null) return;
        draft.Add(new StageDraft
        {
            Title = $"Etapa {draft.Count + 1}",
            Amount = 0,
            DueDate = DateTime.Today.AddDays(Math.Max(7, acceptedProposal.DeliveryDays)),
        });
    }

    private void RemoveStage(int index)
    {
        if (index < 0 || index >= draft.Count || draft.Count <= 1) return;
        draft.RemoveAt(index);
    }

    private void GoBackToStep1()
    {
        currentStep = 1;
        submitError = null;
    }

    private decimal CurrentSum => Math.Round(draft.Sum(s => s.Amount), 2);

    private bool SumMatches =>
        acceptedProposal is not null
        && Math.Abs(CurrentSum - acceptedProposal.Amount) < 0.01m;

    private bool CanConfirm =>
        SumMatches
        && draft.All(s => !string.IsNullOrWhiteSpace(s.Title) && s.Amount > 0);

    private async Task ConfirmAndCreate()
    {
        if (acceptedProposal is null || !CanConfirm || submitting) return;
        submitting = true;
        submitError = null;

        try
        {
            for (var i = 0; i < draft.Count; i++)
            {
                var stage = draft[i];
                var req = new CreateMilestoneRequest
                {
                    ProjectId = ProjectId,
                    Title = stage.Title.Trim(),
                    Description = null,
                    Amount = stage.Amount,
                    Order = i + 1,
                    DueDate = stage.DueDate,
                };
                var created = await Api.CreateMilestoneAsync(req);
                if (created is null)
                {
                    submitError = $"Não foi possível criar a etapa '{stage.Title}'. Tente novamente.";
                    return;
                }
            }

            Toast.ShowSuccess("Etapas criadas com sucesso.");
            Navigation.NavigateTo($"/projects/{ProjectId}/milestones");
        }
        finally
        {
            submitting = false;
        }
    }

    private static decimal ParseDecimal(object? value)
    {
        if (value is null) return 0;
        var s = value.ToString();
        if (string.IsNullOrWhiteSpace(s)) return 0;
        return decimal.TryParse(s, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : 0;
    }

    private static DateTime? ParseDate(object? value)
    {
        var s = value?.ToString();
        if (string.IsNullOrWhiteSpace(s)) return null;
        return DateTime.TryParse(s, System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var d) ? d : null;
    }

    private static async Task<T?> SafeAsync<T>(Func<Task<T?>> call)
    {
        try { return await call(); }
        catch { return default; }
    }

    private class StageDraft
    {
        public string Title { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public DateTime? DueDate { get; set; }
    }
}
