@page "/forgot-password"
@inject ApiClient Api

<PageTitle>Recuperar Senha - decidi</PageTitle>

<div class="auth-container">
    <div class="card" style="padding:2.5rem">
        @if (sent)
        {
            <div style="text-align:center">
                <div style="font-size:3rem;margin-bottom:1rem">&#9993;</div>
                <h1>Verifique seu e-mail</h1>
                <p class="text-muted" style="margin:1rem 0 1.5rem">
                    Se o e-mail <strong>@email</strong> estiver cadastrado, você receberá
                    um link para redefinir sua senha.
                </p>
                <a href="/login" class="btn btn-outline">Voltar ao Login</a>
            </div>
        }
        else
        {
            <h1>Recuperar senha</h1>
            <p class="text-muted text-center mb-3" style="margin-top:-1rem">
                Informe seu e-mail e enviaremos um link para criar uma nova senha.
            </p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="this" OnValidSubmit="HandleSubmit" FormName="forgot">
                <div class="form-group">
                    <label>E-mail</label>
                    <InputText class="form-control" @bind-Value="email" placeholder="seu@email.com"
                        type="email" inputmode="email" autocomplete="email"
                        autocapitalize="off" autocorrect="off" spellcheck="false" />
                </div>

                <SubmitButton IsSubmitting="@loading"
                              Variant="btn-primary" CssClass="btn-lg w-full"
                              BusyText="Enviando...">
                    Enviar Link de Recuperação
                </SubmitButton>
            </EditForm>

            <p style="text-align:center;margin-top:1.5rem;font-size:0.9rem;color:var(--gray-500)">
                Lembrou a senha? <a href="/login">Entrar</a>
            </p>
        }
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? errorMessage;
    private bool loading;
    private bool sent;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Informe seu e-mail.";
            return;
        }

        loading = true;
        errorMessage = null;

        await Api.ForgotPasswordAsync(email);
        sent = true;
        loading = false;
    }
}
