@page "/reset-password"
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>Redefinir Senha - decidi</PageTitle>

<div class="auth-container">
    <div class="card" style="padding:2.5rem">
        @if (success)
        {
            <div style="text-align:center">
                <div style="font-size:3rem;margin-bottom:1rem">&#10003;</div>
                <h1 style="color:var(--success)">Senha redefinida!</h1>
                <p class="text-muted" style="margin:1rem 0 1.5rem">
                    Sua senha foi alterada com sucesso. Faça login com a nova senha.
                </p>
                <a href="/login" class="btn btn-primary btn-lg">Fazer Login</a>
            </div>
        }
        else
        {
            <h1>Redefinir senha</h1>
            <p class="text-muted text-center mb-3" style="margin-top:-1rem">
                Crie uma nova senha para sua conta.
            </p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="reset">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Nova senha <span style="color:var(--error)">*</span></label>
                    <InputText class="form-control" type="password" @bind-Value="model.NewPassword"
                        placeholder="Crie uma nova senha"
                        autocomplete="new-password" autocapitalize="off" autocorrect="off" spellcheck="false" />
                    <ValidationMessage For="@(() => model.NewPassword)" />
                </div>

                <div class="form-group">
                    <label>Confirmar nova senha <span style="color:var(--error)">*</span></label>
                    <InputText class="form-control" type="password" @bind-Value="model.ConfirmPassword"
                        placeholder="Repita a nova senha"
                        autocomplete="new-password" autocapitalize="off" autocorrect="off" spellcheck="false" />
                    <ValidationMessage For="@(() => model.ConfirmPassword)" />
                </div>

                <SubmitButton IsSubmitting="@loading"
                              Variant="btn-primary" CssClass="btn-lg w-full"
                              BusyText="Redefinindo...">
                    Redefinir Senha
                </SubmitButton>
            </EditForm>

            <p style="text-align:center;margin-top:1.5rem;font-size:0.9rem;color:var(--gray-500)">
                <a href="/login">Voltar ao Login</a>
            </p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private ResetPasswordModel model = new();
    private string? errorMessage;
    private bool loading;
    private bool success;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Token))
            errorMessage = "Link de redefinição inválido.";
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Token))
        {
            errorMessage = "Link de redefinição inválido.";
            return;
        }

        loading = true;
        errorMessage = null;

        var result = await Api.ResetPasswordAsync(Email, Uri.UnescapeDataString(Token), model.NewPassword, model.ConfirmPassword);
        if (result)
            success = true;
        else
            errorMessage = "Não foi possível redefinir a senha. O link pode ter expirado.";

        loading = false;
    }

    private class ResetPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Senha é obrigatória")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Mínimo 6 caracteres")]
        public string NewPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Confirmação é obrigatória")]
        [System.ComponentModel.DataAnnotations.Compare(nameof(NewPassword), ErrorMessage = "Senhas não conferem")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
