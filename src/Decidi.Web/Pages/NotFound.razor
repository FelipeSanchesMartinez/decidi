@page "/not-found"

<PageTitle>Página não encontrada - decidi</PageTitle>

<div class="container" style="padding:4rem 0">
    <div class="text-center">
        <h1 style="font-size:5rem;font-weight:800;background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:0.5rem">404</h1>
        <h2 style="margin-bottom:0.75rem">Página não encontrada</h2>
        <p class="text-muted" style="margin-bottom:2rem">A página que você procura não existe ou foi movida.</p>
        <div class="flex gap-1" style="justify-content:center">
            <a href="/" class="btn btn-primary">Voltar ao Início</a>
            <a href="/projects" class="btn btn-secondary">Ver Projetos</a>
        </div>
    </div>
</div>
